{
  "name": "micro-podcasts",
  "version": "0.0.0",
  "scripts": {
    "ng": "ng",
    "start": "ng serve",
    "restart": "bash stop.sh ;bash start.sh",
    "build": "ng build shared-utils && ng build host-app",
    "build:prod": "ng build shared-utils && ng build host-app --configuration production",
    "watch": "ng build --watch --configuration development",
    "test": "ng test",
    "storybook": "ng run host-app:storybook",
    "build-storybook": "ng run host-app:build-storybook"
  },
  "prettier": {
    "printWidth": 100,
    "singleQuote": true,
    "overrides": [
      {
        "files": "*.html",
        "options": {
          "parser": "angular"
        }
      }
    ]
  },
  "private": true,
  "packageManager": "npm@10.8.2",
  "dependencies": {
    "@angular-architects/native-federation": "^21.2.5",
    "@angular/animations": "^21.0.0",
    "@angular/common": "^21.0.0",
    "@angular/compiler": "^21.0.0",
    "@angular/core": "^21.0.0",
    "@angular/forms": "^21.0.0",
    "@angular/platform-browser": "^21.0.0",
    "@angular/router": "^21.0.0",
    "@softarc/native-federation-node": "^3.3.4",
    "es-module-shims": "^2.8.1",
    "rxjs": "~7.8.0",
    "tslib": "^2.3.0"
  },
  "devDependencies": {
    "@angular-devkit/build-angular": "^21.2.16",
    "@angular/build": "^21.2.16",
    "@angular/cli": "^21.0.4",
    "@angular/compiler-cli": "^21.0.0",
    "@compodoc/compodoc": "^1.2.1",
    "@storybook/addon-docs": "^10.4.6",
    "@storybook/angular": "^10.4.6",
    "jsdom": "^28.0.0",
    "ng-packagr": "^21.2.0",
    "storybook": "^10.4.6",
    "typescript": "~5.9.2",
    "vitest": "^4.0.8"
  }
}
